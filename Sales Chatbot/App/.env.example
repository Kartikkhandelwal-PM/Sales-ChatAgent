# ── KDK Sales Chatbot — Environment Variables ──
# Copy this file to .env and fill in your values

# Your OpenAI API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model to use (gpt-4o-mini is recommended for cost efficiency)
OPENAI_MODEL=gpt-4o-mini

# Port (default: 3000)
PORT=3000

# PostgreSQL (for conversation logging — leave blank to disable)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kdk_chatbot
DB_USER=postgres
DB_PASSWORD=yourpassword
